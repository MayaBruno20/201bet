# Database (NeonDB - PostgreSQL)
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"

# Auth
JWT_SECRET="change-me"
JWT_EXPIRES_IN="8h"

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://<your-upstash-url>"
UPSTASH_REDIS_REST_TOKEN="<your-upstash-token>"

# Optional Google Login
GOOGLE_CLIENT_ID=""

# Valut Global - OpenBanking API (PIX)
VALUT_API_KEY="<your-valut-api-key>"
VALUT_API_SECRET="<your-valut-api-secret>"
VALUT_USERNAME="<your-valut-username>"
VALUT_PASSWORD="<your-valut-password>"
VALUT_WEBHOOK_SECRET="<optional-webhook-auth-secret>"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3502/api"
NEXT_PUBLIC_WS_URL="http://localhost:3502/realtime"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
