# Database (NeonDB - PostgreSQL)
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"
# Migrações (raiz): `npm run db:migrate:deploy`. Se aparecer P3005 (base já tem tabelas sem histórico Prisma),
# típico em Docker local: `npm run db:migrate:baseline-local` ou, se o schema já tiver tudo, `npm run db:migrate:resolve-all` e depois deploy.

# Auth (JWT em cookie httpOnly `201bet_access`; o front usa credentials: include)
JWT_SECRET="change-me"
JWT_EXPIRES_IN="8h"
# CORS_ORIGIN: origem exata do Next (várias: separadas por vírgula). Sem wildcard.
# Se o site (Vercel) e a API forem domínios diferentes, é obrigatório:
AUTH_COOKIE_SAMESITE="none"
# AUTH_COOKIE_DOMAIN só se API e front partilharem o mesmo eTLD+1 (não é o caso típico Vercel + Render).

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional Google Login
GOOGLE_CLIENT_ID=""

# Valut Global - OpenBanking API (PIX)
VALUT_API_KEY="<your-valut-api-key>"
VALUT_API_SECRET="<your-valut-api-secret>"
VALUT_USERNAME="<your-valut-username>"
VALUT_PASSWORD="<your-valut-password>"
# Obrigatório: o webhook Valut exige este valor no header Authorization (Bearer/Basic)
VALUT_WEBHOOK_SECRET="<valut-webhook-shared-secret>"

# Múltiplas instâncias do backend: use false em todas exceto uma para a simulação de mercado (ticks fictícios)
# MARKET_SIMULATION_LEADER=false

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3502/api"
NEXT_PUBLIC_WS_URL="http://localhost:3502/realtime"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
