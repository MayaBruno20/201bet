# Database (NeonDB - PostgreSQL)
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"
# Migrações (raiz): `npm run db:migrate:deploy`. Se aparecer P3005 (base já tem tabelas sem histórico Prisma),
# típico em Docker local: `npm run db:migrate:baseline-local` ou, se o schema já tiver tudo, `npm run db:migrate:resolve-all` e depois deploy.

# Auth (JWT em cookie httpOnly `201bet_access`; o front usa credentials: include)
JWT_SECRET="change-me"
JWT_EXPIRES_IN="8h"
# CORS_ORIGIN deve incluir a origem exata do Next (ex.: http://localhost:3501)
# Se front e API forem domínios diferentes em produção (HTTPS): AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_DOMAIN=.example.com

# Cache (Upstash Redis REST — NÃO é usado pela fila, só como cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional Google Login
GOOGLE_CLIENT_ID=""

# Valut Global - OpenBanking API (PIX)
VALUT_API_KEY="<your-valut-api-key>"
VALUT_API_SECRET="<your-valut-api-secret>"
VALUT_USERNAME="<your-valut-username>"
VALUT_PASSWORD="<your-valut-password>"
# Obrigatório: o webhook Valut exige este valor no header Authorization (Bearer/Basic)
VALUT_WEBHOOK_SECRET="<valut-webhook-shared-secret>"

# Múltiplas instâncias do backend: use false em todas exceto uma para a simulação de mercado (ticks fictícios)
# MARKET_SIMULATION_LEADER=false

# Frontend (URL base do front, usada para montar os links dos e-mails)
# dev: http://localhost:3501 | staging: https://staging.201-bet.com | prod: https://201-bet.com
FRONTEND_URL="http://localhost:3501"

# Redis TCP (fila BullMQ — separado do Upstash REST)
# Em dev, o docker-compose.yml sobe redis:7-alpine em localhost:3505
REDIS_HOST="localhost"
REDIS_PORT=3505
REDIS_PASSWORD=""
REDIS_TLS="false"

# === E-mail transacional ===
# Provider: brevo | mailtrap | noop
# - noop: não envia nada (default seguro, usar em CI/testes)
# - mailtrap: dev — inbox fake, credenciais em https://mailtrap.io → Email Testing → My Inbox → Integrations → Nodemailer
# - brevo: staging/prod — API key em https://app.brevo.com → SMTP & API → API Keys
EMAIL_PROVIDER="noop"
EMAIL_FROM_ADDRESS="no-reply@201-bet.com"
EMAIL_FROM_NAME="201Bet"
EMAIL_REPLY_TO="suporte@201-bet.com"
EMAIL_DAILY_LIMIT=295
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30
# URL pública da logo nos e-mails. Sobrescreve o default ${FRONTEND_URL}/images/logo.png.
# Use em dev (Mailtrap não consegue acessar localhost) apontando para um host público.
EMAIL_LOGO_URL=""

# Brevo (só preencha quando EMAIL_PROVIDER=brevo)
BREVO_API_KEY=""

# Mailtrap (só preencha quando EMAIL_PROVIDER=mailtrap)
MAILTRAP_SMTP_HOST="sandbox.smtp.mailtrap.io"
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=""
MAILTRAP_SMTP_PASS=""

# Frontend (variáveis públicas do Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3502/api"
NEXT_PUBLIC_WS_URL="http://localhost:3502/realtime"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
