neon_api_key      = ""
upstash_api_key   = ""
upstash_email     = ""

# Free tier Upstash: limite de 1 Redis — use Redis já criado no console em vez de resource Terraform.
# create_upstash_redis  = false
# upstash_rest_url      = "https://<id>.upstash.io"
# upstash_rest_token    = "<REST token no console>"
vercel_api_token  = ""
github_token      = ""
github_owner      = ""
github_repo       = ""
enable_github_secrets = true

jwt_secret        = ""
jwt_expires_in    = "8h"
cors_origin       = "https://<staging-frontend>.vercel.app"
vercel_project_name = "201bet-frontend-staging"
frontend_url      = "https://<staging-frontend>.vercel.app"
email_provider    = "noop"
email_from_address = "no-reply@201-bet.com"
email_from_name   = "201Bet"
email_reply_to    = "suporte@201-bet.com"
email_daily_limit = 295
email_verification_ttl_hours = 24
password_reset_ttl_minutes = 30
email_logo_url    = ""
quotaguardstatic_url = ""

# Se enable_render_web_service = true, use backend_public_url = "" (URL vem do Render).
backend_public_url = "https://<backend-staging>.onrender.com"

enable_render_web_service = false
render_api_key            = ""
render_owner_id           = ""
