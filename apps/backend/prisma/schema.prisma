generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  OPERATOR
  AUDITOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum EventStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELED
}

enum MarketStatus {
  OPEN
  SUSPENDED
  CLOSED
  SETTLED
}

enum OddStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum BetStatus {
  OPEN
  WON
  LOST
  CANCELED
  REFUNDED
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAW
  BET_PLACED
  BET_WON
  BET_REFUND
  BONUS
  ADJUSTMENT
  AFFILIATE_COMMISSION
}

enum PaymentType {
  DEPOSIT
  WITHDRAW
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  CANCELED
}

enum BonusStatus {
  PENDING
  ACTIVE
  CONSUMED
  CANCELED
  EXPIRED
}

enum DuelStatus {
  SCHEDULED
  BOOKING_OPEN
  BOOKING_CLOSED
  FINISHED
  CANCELED
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum MarketType {
  DUEL
  WINNER
  BEST_REACTION
  FALSE_START
}

enum ListFormat {
  TOP_10
  TOP_20
}

enum ListRoundType {
  ODD
  EVEN
  SHARK_TANK
}

enum MatchupSide {
  LEFT
  RIGHT
}

enum ListEventStatus {
  DRAFT
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum ListEventType {
  REGULAR
  ARMAGEDDON
  SHARK_TANK
}

enum SharkTankStatus {
  REGISTERED
  ELIMINATED
  FINALIST
  PROMOTED
}

enum CategoryEventStatus {
  DRAFT
  REGISTRATION_OPEN
  QUALIFYING
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum TimeCategory {
  ORIGINAL_10S
  CAT_9S
  CAT_8_5S
  CAT_8S
  CAT_7_5S
  CAT_7S
  CAT_6_5S
  CAT_6S
  CAT_5_5S
  TUDOKIDA
}

enum CategoryMatchupStatus {
  PENDING
  COMPLETED
  INVALIDATED
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  name          String
  firstName     String?
  lastName      String?
  cpf           String?    @unique
  birthDate     DateTime?
  phone         String?
  country       String?
  state         String?
  city          String?
  address       String?
  postalCode    String?
  nationality   String?
  gender        String?
  avatarUrl     String?
  emailVerified Boolean    @default(false)
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  googleSub     String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  affiliateId String?

  wallet             Wallet?
  bets               Bet[]
  payments           Payment[]
  bonuses            Bonus[]
  auditLogs          AuditLog[]          @relation("auditActor")
  settings           GlobalSetting[]     @relation("settingsUpdatedBy")
  verificationTokens VerificationToken[]
  affiliate          Affiliate?          @relation("affiliateUsers", fields: [affiliateId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([role])
  @@index([affiliateId])
}

model VerificationToken {
  id        String                @id @default(uuid())
  userId    String
  tokenHash String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(20, 4)
  currency  String   @default("BRL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  ledger WalletTransaction[]
}

model WalletTransaction {
  id        String                @id @default(uuid())
  walletId  String
  type      WalletTransactionType
  amount    Decimal               @db.Decimal(20, 4)
  reference String?
  createdAt DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([walletId, createdAt])
  @@index([type])
}

model Event {
  id          String      @id @default(uuid())
  sport       String
  name        String
  description String?
  bannerUrl   String?
  featured    Boolean     @default(false)
  startAt     DateTime
  status      EventStatus @default(SCHEDULED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  markets Market[]
  duels   Duel[]

  @@index([startAt])
  @@index([status])
  @@index([featured])
}

model Driver {
  id        String   @id @default(uuid())
  name      String
  nickname  String?
  carNumber String?
  team      String?
  hometown  String?
  avatarUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cars                Car[]
  rosters             ListRoster[]
  leftMatchups        ListMatchup[]        @relation("matchupLeftDriver")
  rightMatchups       ListMatchup[]        @relation("matchupRightDriver")
  sharkTankEntries    SharkTankEntry[]     @relation("sharkTankDriver")
  categoryCompetitors CategoryCompetitor[]

  @@index([active])
}

model Car {
  id        String   @id @default(uuid())
  driverId  String
  name      String
  category  String
  number    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver     Driver @relation(fields: [driverId], references: [id], onDelete: Restrict)
  leftDuels  Duel[] @relation("leftCar")
  rightDuels Duel[] @relation("rightCar")

  @@index([driverId])
  @@index([active])
}

model Duel {
  id             String     @id @default(uuid())
  eventId        String
  leftCarId      String
  rightCarId     String
  startsAt       DateTime
  bookingCloseAt DateTime
  status         DuelStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  event     Event          @relation(fields: [eventId], references: [id], onDelete: Restrict)
  leftCar   Car            @relation("leftCar", fields: [leftCarId], references: [id], onDelete: Restrict)
  rightCar  Car            @relation("rightCar", fields: [rightCarId], references: [id], onDelete: Restrict)
  poolState DuelPoolState?
  markets   Market[]

  @@index([eventId, startsAt])
  @@index([status])
}

model DuelPoolState {
  duelId       String   @id
  leftPool     Decimal  @default(0) @db.Decimal(20, 4)
  rightPool    Decimal  @default(0) @db.Decimal(20, 4)
  leftTickets  Int      @default(0)
  rightTickets Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  duel Duel @relation(fields: [duelId], references: [id], onDelete: Cascade)
}

model Market {
  id             String       @id @default(uuid())
  eventId        String
  name           String
  type           MarketType   @default(DUEL)
  status         MarketStatus @default(OPEN)
  rakePercent    Decimal?     @db.Decimal(5, 2)
  winnerOddId    String?
  settledAt      DateTime?
  duelId         String?
  bookingCloseAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  event       Event                 @relation(fields: [eventId], references: [id], onDelete: Restrict)
  duel        Duel?                 @relation(fields: [duelId], references: [id], onDelete: Restrict)
  odds        Odd[]
  commissions AffiliateCommission[]

  @@index([eventId])
  @@index([status])
  @@index([type])
  @@index([duelId])
}

model Odd {
  id        String    @id @default(uuid())
  marketId  String
  label     String
  value     Decimal   @db.Decimal(12, 4)
  status    OddStatus @default(ACTIVE)
  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  market   Market    @relation(fields: [marketId], references: [id], onDelete: Restrict)
  betItems BetItem[]

  @@index([marketId, status])
}

model Bet {
  id           String    @id @default(uuid())
  userId       String
  stake        Decimal   @db.Decimal(20, 4)
  potentialWin Decimal   @db.Decimal(20, 4)
  status       BetStatus @default(OPEN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  items       BetItem[]
  commissions AffiliateCommission[]

  @@index([userId, createdAt])
  @@index([status])
}

model BetItem {
  id             String  @id @default(uuid())
  betId          String
  oddId          String
  oddAtPlacement Decimal @db.Decimal(12, 4)

  bet Bet @relation(fields: [betId], references: [id], onDelete: Restrict)
  odd Odd @relation(fields: [oddId], references: [id], onDelete: Restrict)

  @@index([betId])
  @@index([oddId])
}

model Payment {
  id          String        @id @default(uuid())
  userId      String
  type        PaymentType
  amount      Decimal       @db.Decimal(20, 4)
  status      PaymentStatus @default(PENDING)
  provider    String
  providerRef String?
  // Para WITHDRAW: persiste o destino do PIX para possibilitar review manual e retry
  pixKey      String?
  pixKeyType  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([status, type])
}

model Bonus {
  id        String      @id @default(uuid())
  userId    String
  amount    Decimal     @db.Decimal(20, 4)
  wagering  Int
  status    BonusStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status])
}

model GlobalSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  updatedBy User? @relation("settingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String?
  payload     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actorUser User? @relation("auditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entity, createdAt])
}

model Affiliate {
  id            String   @id @default(uuid())
  name          String
  code          String   @unique
  commissionPct Decimal  @db.Decimal(5, 2)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  referredUsers User[]                @relation("affiliateUsers")
  commissions   AffiliateCommission[]

  @@index([code])
  @@index([active])
}

model AffiliateCommission {
  id          String   @id @default(uuid())
  affiliateId String
  betId       String
  marketId    String
  amount      Decimal  @db.Decimal(20, 4)
  createdAt   DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  bet       Bet       @relation(fields: [betId], references: [id], onDelete: Restrict)
  market    Market    @relation(fields: [marketId], references: [id], onDelete: Restrict)

  @@index([affiliateId, createdAt])
  @@index([betId])
  @@index([marketId])
}

model BrazilList {
  id                String     @id @default(uuid())
  areaCode          Int        @unique
  name              String
  format            ListFormat @default(TOP_20)
  administratorName String?
  hometown          String?
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  roster ListRoster[]
  events ListEvent[]

  @@index([active])
}

model ListRoster {
  id        String   @id @default(uuid())
  listId    String
  driverId  String
  position  Int
  isKing    Boolean  @default(false)
  joinedAt  DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list   BrazilList @relation(fields: [listId], references: [id], onDelete: Cascade)
  driver Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)

  @@unique([listId, position])
  @@unique([listId, driverId])
  @@index([listId])
  @@index([driverId])
}

model ListEvent {
  id          String          @id @default(uuid())
  listId      String
  name        String
  scheduledAt DateTime
  endsAt      DateTime?
  status      ListEventStatus @default(DRAFT)
  type        ListEventType   @default(REGULAR)
  eventId     String?
  bannerUrl   String?
  featured    Boolean         @default(false)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  list      BrazilList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  matchups  ListMatchup[]
  sharkTank SharkTankEntry[]

  @@index([listId, scheduledAt])
  @@index([status])
}

model ListMatchup {
  id               String        @id @default(uuid())
  listEventId      String
  roundNumber      Int
  roundType        ListRoundType
  order            Int
  leftPosition     Int?
  rightPosition    Int?
  leftDriverId     String?
  rightDriverId    String?
  winnerSide       MatchupSide?
  isManualOverride Boolean       @default(false)
  marketOpen       Boolean       @default(false)
  duelId           String?       @unique
  settledAt        DateTime?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  listEvent   ListEvent @relation(fields: [listEventId], references: [id], onDelete: Cascade)
  leftDriver  Driver?   @relation("matchupLeftDriver", fields: [leftDriverId], references: [id], onDelete: SetNull)
  rightDriver Driver?   @relation("matchupRightDriver", fields: [rightDriverId], references: [id], onDelete: SetNull)

  @@index([listEventId, roundNumber, order])
  @@index([marketOpen])
}

model SharkTankEntry {
  id          String          @id @default(uuid())
  listEventId String
  driverId    String
  status      SharkTankStatus @default(REGISTERED)
  seed        Int?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  listEvent ListEvent @relation(fields: [listEventId], references: [id], onDelete: Cascade)
  driver    Driver    @relation("sharkTankDriver", fields: [driverId], references: [id], onDelete: Restrict)

  @@unique([listEventId, driverId])
  @@index([listEventId, status])
}

// ─── Copa Categorias ─────────────────────────────────────

model CategoryEvent {
  id          String              @id @default(uuid())
  name        String
  description String?
  bannerUrl   String?
  featured    Boolean             @default(false)
  scheduledAt DateTime
  endsAt      DateTime?
  status      CategoryEventStatus @default(DRAFT)
  // Link com Event (criado uma vez, reusado em todos os matchups que abrirem mercado)
  eventId     String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  brackets CategoryBracket[]

  @@index([status])
  @@index([scheduledAt])
  @@index([featured])
}

model CategoryBracket {
  id              String       @id @default(uuid())
  categoryEventId String
  category        TimeCategory
  size            Int          @default(8)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  categoryEvent CategoryEvent        @relation(fields: [categoryEventId], references: [id], onDelete: Cascade)
  competitors   CategoryCompetitor[]
  matchups      CategoryMatchup[]

  @@unique([categoryEventId, category])
}

model CategoryCompetitor {
  id        String  @id @default(uuid())
  bracketId String
  driverId  String
  carName   String
  carNumber String?

  qualifyingReaction Decimal? @db.Decimal(8, 3)
  qualifyingTrack    Decimal? @db.Decimal(8, 3)
  qualifyingTotal    Decimal? @db.Decimal(8, 3)
  qualifyingPosition Int?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bracket CategoryBracket   @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  driver  Driver            @relation(fields: [driverId], references: [id], onDelete: Restrict)
  asLeft  CategoryMatchup[] @relation("CategoryMatchupLeft")
  asRight CategoryMatchup[] @relation("CategoryMatchupRight")

  @@unique([bracketId, driverId])
  @@index([bracketId, qualifyingPosition])
}

model CategoryMatchup {
  id           String  @id @default(uuid())
  bracketId    String
  roundNumber  Int
  position     Int
  isSuperFinal Boolean @default(false)

  // Link com sistema de apostas (criado quando admin abre o mercado)
  duelId     String?  @unique
  marketOpen Boolean  @default(false)

  leftCompetitorId  String?
  rightCompetitorId String?

  leftReaction Decimal? @db.Decimal(8, 3)
  leftTrack    Decimal? @db.Decimal(8, 3)
  leftQueimou  Boolean  @default(false)
  leftInvalid  Boolean  @default(false)

  rightReaction Decimal? @db.Decimal(8, 3)
  rightTrack    Decimal? @db.Decimal(8, 3)
  rightQueimou  Boolean  @default(false)
  rightInvalid  Boolean  @default(false)

  winnerSide MatchupSide?
  status     CategoryMatchupStatus @default(PENDING)
  settledAt  DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bracket         CategoryBracket     @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  leftCompetitor  CategoryCompetitor? @relation("CategoryMatchupLeft", fields: [leftCompetitorId], references: [id], onDelete: SetNull)
  rightCompetitor CategoryCompetitor? @relation("CategoryMatchupRight", fields: [rightCompetitorId], references: [id], onDelete: SetNull)

  @@unique([bracketId, roundNumber, position])
  @@index([bracketId, roundNumber])
}
